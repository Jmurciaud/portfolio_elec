---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Portfolio">
  <section class="hero">
    <h1>Proyectos</h1>
    <p class="hero-sub">Electrónica y software — construyendo cosas que funcionan.</p>
  </section>
</Layout>

<style>
  .hero {
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--text);
  }

  .hero-sub {
    margin-top: 0.75rem;
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
  }
</style>
