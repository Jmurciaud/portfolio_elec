---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const proyectos = (await getCollection('proyectos')).sort((a, b) => {
  if (a.data.destacado !== b.data.destacado) return a.data.destacado ? -1 : 1;
  return b.data.fecha.getTime() - a.data.fecha.getTime();
});

const totalElectronica = proyectos.filter(p => p.data.categoria === 'electronica').length;
const totalSoftware = proyectos.filter(p => p.data.categoria === 'software').length;
---

<Layout title="Portfolio WIRE Ingeniería — Electrónica & Software">
  <section class="hero">
    <h1>Proyectos</h1>
    <p class="hero-sub">Electrónica y software — construyendo cosas que funcionan.</p>
  </section>

  <div class="filters" role="group" aria-label="Filtrar proyectos">
    <button class="filter-btn active" data-filter="todos">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Todos <span class="filter-count">{proyectos.length}</span>
    </button>
    <button class="filter-btn" data-filter="electronica">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="14" x2="22" y2="14"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="14" x2="4" y2="14"/></svg>
      Electrónica <span class="filter-count">{totalElectronica}</span>
    </button>
    <button class="filter-btn" data-filter="software">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      Software <span class="filter-count">{totalSoftware}</span>
    </button>
  </div>

  <div class="projects-grid" id="projects-grid">
    {proyectos.map(proyecto => (
      <ProjectCard proyecto={proyecto} />
    ))}
  </div>

  <p class="empty-msg" id="empty-msg" hidden>
    No hay proyectos en esta categoría todavía.
  </p>
</Layout>

<style>
  .hero {
    padding: 2.5rem 0 2rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
  }

  .hero-sub {
    margin-top: 0.6rem;
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.25rem;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.15rem;
    border-radius: 999px;
    border: 1.5px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: border-color 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s, transform 0.15s;
  }

  .filter-btn svg {
    flex-shrink: 0;
    transition: stroke 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--accent-light);
    color: var(--text);
    background: rgba(99, 102, 241, 0.08);
    transform: translateY(-1px);
  }

  .filter-btn:active {
    transform: translateY(0);
  }

  .filter-btn.active {
    background: linear-gradient(135deg, var(--accent) 0%, #8b5cf6 100%);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 4px 18px rgba(99, 102, 241, 0.45), 0 1px 3px rgba(0,0,0,0.3);
    transform: translateY(-1px);
  }

  .filter-btn.active .filter-count {
    background: rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.9);
  }

  .filter-count {
    background: var(--tag-bg);
    color: var(--text-muted);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 1.4rem;
    text-align: center;
    transition: background 0.2s, color 0.2s;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .empty-msg {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');
  const emptyMsg = document.getElementById('empty-msg');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      let visible = 0;
      cards.forEach(card => {
        const show = filter === 'todos' || card.dataset.category === filter;
        card.hidden = !show;
        if (show) visible++;
      });

      if (emptyMsg) emptyMsg.hidden = visible > 0;
    });
  });
</script>
